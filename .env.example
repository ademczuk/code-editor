# ──────────────────────────────────────────────────────────────
# Knot Code – Environment Variables
# ──────────────────────────────────────────────────────────────

# GitHub OAuth App Client ID (for device-flow auth)
# Create at: https://github.com/settings/developers
NEXT_PUBLIC_GITHUB_CLIENT_ID=

# Spotify — PKCE OAuth (no secret needed, safe for public apps)
# Create at: https://developer.spotify.com/dashboard
# Add redirect URI http://127.0.0.1:3080 (Spotify requires 127.0.0.1, not localhost)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
